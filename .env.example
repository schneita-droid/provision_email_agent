# Anthropic API key for AI categorization + draft generation (required for AI features)
# This key is only used server-side (Vercel Functions) — never exposed to browser
ANTHROPIC_API_KEY=

# Vercel KV credentials (optional — without these, uses localStorage instead)
# Create a KV store at: Vercel Dashboard → Storage → Create → KV
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Google OAuth2 Client ID for Gmail integration (optional — uses demo data without it)
# This is safe to expose client-side (it's a public identifier, not a secret)
VITE_GOOGLE_CLIENT_ID=
